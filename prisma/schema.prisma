generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum OAuthProvider {
  GOOGLE
  GITHUB
  YANDEX
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  oauthAccounts OAuthAccount[]
  courses       Course[]

  @@map("users")
}

model OAuthAccount {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  createdAt         DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Course {
  id            String        @id @default(uuid()) @db.Uuid
  authorId      String        @map("author_id") @db.Uuid
  title         String
  slug          String        @unique
  description   String        @db.Text
  coverImageUrl String?       @map("cover_image_url")
  status        ContentStatus @default(DRAFT)
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([status, sortOrder])
  @@map("courses")
}

model Lesson {
  id        String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title     String
  slug      String
  content   String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
  @@map("lessons")
}

model Article {
  id            String        @id @default(uuid()) @db.Uuid
  slug          String        @unique
  coverImageUrl String?       @map("cover_image_url")
  status        ContentStatus @default(DRAFT)
  viewCount     Int           @default(0) @map("view_count")
  publishedAt   DateTime?     @map("published_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  translations ArticleTranslation[]
  tags         Tag[]                @relation("ArticleTags")

  @@index([status, publishedAt(sort: Desc)])
  @@map("articles")
}

model ArticleTranslation {
  id          String @id @default(uuid()) @db.Uuid
  articleId   String @map("article_id") @db.Uuid
  language    String @db.VarChar(2)
  title       String
  description String @db.Text
  content     String @db.Text

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, language])
  @@index([language])
  @@map("article_translations")
}

model Tag {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique
  slug String @unique

  articles Article[] @relation("ArticleTags")

  @@map("tags")
}

// ─── Roadmap ──────────────────────────────────────────────────────────────

model RoadmapSection {
  id        String        @id @default(uuid()) @db.Uuid
  key       String        @unique
  isNew     Boolean       @default(false) @map("is_new")
  status    ContentStatus @default(DRAFT)
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  categories RoadmapCategory[]

  @@index([status, sortOrder])
  @@map("roadmap_sections")
}

model RoadmapCategory {
  id        String @id @default(uuid()) @db.Uuid
  sectionId String @map("section_id") @db.Uuid
  key       String
  sortOrder Int    @default(0) @map("sort_order")

  section RoadmapSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items   RoadmapItem[]

  @@unique([sectionId, key])
  @@index([sectionId, sortOrder])
  @@map("roadmap_categories")
}

model RoadmapItem {
  id         String @id @default(uuid()) @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  key        String
  iconUrl    String @map("icon_url")
  iconAlt    String @map("icon_alt")
  sortOrder  Int    @default(0) @map("sort_order")

  category RoadmapCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  links    RoadmapLink[]

  @@unique([categoryId, key])
  @@index([categoryId, sortOrder])
  @@map("roadmap_items")
}

model RoadmapLink {
  id        String  @id @default(uuid()) @db.Uuid
  itemId    String  @map("item_id") @db.Uuid
  label     String
  url       String
  type      String? @db.VarChar(10)
  sortOrder Int     @default(0) @map("sort_order")

  item RoadmapItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
  @@map("roadmap_links")
}
