# Application
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=blog_user
DB_PASSWORD=blog_pass
DB_NAME=blog_platform
DATABASE_URL=postgresql://blog_user:blog_pass@localhost:5432/blog_platform?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=7d

# OAuth: Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth: GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# OAuth: Yandex
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=http://localhost:3000/auth/yandex/callback

# Frontend URL (for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:3001
